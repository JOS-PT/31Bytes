<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reconhecedor Soft UI" Height="523" Width="976" 
        Background="#E0E5EC" KeyUp="DrawPanel_KeyUp" FontFamily="Segoe UI" 
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="ExtrudeEffectStyle" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Direction="315" Opacity="0.5" ShadowDepth="6" Color="#A3B1C6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InsetEffectStyle" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Direction="135" Opacity="0.5" ShadowDepth="6" Color="#A3B1C6" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftButton" TargetType="Button">
            <Setter Property="Background" Value="#E0E5EC"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D1D9E6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" Direction="135" Opacity="0.5" ShadowDepth="6" Color="#A3B1C6" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Direction="315" Opacity="0.5" ShadowDepth="6" Color="#A3B1C6"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,20,-22">

            <Border Background="#E0E5EC" CornerRadius="10,10,0,0" Padding="10,5" Style="{StaticResource ExtrudeEffectStyle}" Margin="0,0,0,-1">
                <ToolBar Background="Transparent" BorderThickness="0" BorderBrush="#C4CDD5">
                    <RadioButton Content="Lápis" GroupName="drawgroup" IsChecked="True" Click="DrawButton_Click" ToolTip="Modo Desenho (Teclas 1, 2, 3 para tamanho, B, G para cor)" Width="59" Background="#40E8EDF1" FontSize="14" FontWeight="Bold"/>
                    <RadioButton Content="Borracha" GroupName="drawgroup" Click="DrawButton_Click" ToolTip="Modo Borracha" Width="66" FontWeight="Bold" FontSize="14"/>
                    <RadioButton Content="Selecionar" GroupName="drawgroup" Click="DrawButton_Click" ToolTip="Modo Seleção de Traços" Width="95" FontWeight="Bold" FontSize="14"/>
                    <Separator Background="#C4CDD5"/>
                    <Button Content="Abrir desenho guardado" Click="OpenButton_Click" FontWeight="Bold" FontSize="14"/>
                    <Button Content="Guardar desenho" Click="SaveButton_Click" Width="129" FontWeight="Bold" FontSize="14"/>
                </ToolBar>
            </Border>

            <Border Background="#E0E5EC" CornerRadius="0,0,10,10" Style="{StaticResource ExtrudeEffectStyle}" Padding="15">
                <Grid>
                    <Border CornerRadius="5" Background="#E0E5EC" Style="{StaticResource InsetEffectStyle}">
                        <InkCanvas x:Name="DrawingCanvas" 
                                   Width="400" Height="300" 
                                   Background="White" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center">
                            <InkCanvas.DefaultDrawingAttributes>
                                <DrawingAttributes Width="3" Height="3" Color="Black" FitToCurve="True"/>
                            </InkCanvas.DefaultDrawingAttributes>
                        </InkCanvas>
                    </Border>

                    <TextBlock Text="31Bytes" Foreground="#A0A0A0" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button Content="Apagar" Click="EraseAll_Click" 
                        Width="120" Height="40" Margin="0,0,25,0" 
                        Style="{StaticResource SoftButton}" Foreground="#D32F2F" ToolTip="Limpar todo o canvas" FontSize="18"/>

                <Button Content="Identificar" Click="IdentifyNumber_Click" 
                        Width="150" Height="40"
                        Style="{StaticResource SoftButton}" Foreground="#388E3C" ToolTip="Executar reconhecimento" FontSize="18"/>
            </StackPanel>

        </StackPanel>

        <Border Grid.Column="1" Background="#E0E5EC" CornerRadius="10" Padding="20" Style="{StaticResource ExtrudeEffectStyle}">
            <Grid VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="RESULTADO" Foreground="#546E7A" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-70,0,80"/>

                <Separator Grid.Row="0" VerticalAlignment="Bottom" Background="#C4CDD5"/>

                <TextBlock Text="O número desenhado foi:" Foreground="#78909C" FontSize="16" HorizontalAlignment="Center" Margin="0,-17,0,25"/>

                <Border Grid.Row="2" Background="#E0E5EC" CornerRadius="10" Margin="0,10,0,0" Style="{StaticResource InsetEffectStyle}">
                    <TextBlock x:Name="ResultTextBlock" 
                               Text="?" 
                               FontSize="120" FontWeight="Thin" 
                               Foreground="#388E3C" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Margin="0,-10,0,0"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>